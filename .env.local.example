# ============================================================
# TicketWiFiZone — Variables d'environnement
# ============================================================
# Copiez ce fichier vers .env.local et remplissez les valeurs

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# --- Africa's Talking (envoi SMS) ---
# Créez un compte sur https://africastalking.com
# En mode sandbox, utilisez AT_USERNAME=sandbox
AT_API_KEY=your_africastalking_api_key_here
AT_USERNAME=sandbox
AT_SENDER_ID=TicketWiFi

# --- Application ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# En production : https://ticketswifizone.com

# --- Optionnel : Logs ---
# LOG_LEVEL=debug
